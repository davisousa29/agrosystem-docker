# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="AgroSystem"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Banco de dados ─────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=agro_db
DB_USERNAME=agro_user
DB_PASSWORD=secret_change_me

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
